    "@vue/test-utils": "^2.4.11",
    "nuxt": "^3.8.2",
    "sass": "^1.60.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.1.10",
    "vuetify": "^3.1.12"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.4.15",
    "vite-plugin-vuetify": "^1.0.2"

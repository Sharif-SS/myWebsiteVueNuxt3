{
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "set NODE_OPTIONS=--no-deprecation&& nuxt build",
    "dev": "set NODE_OPTIONS=--no-deprecation&& nuxt dev --host",
    "generate": "set NODE_OPTIONS=--no-deprecation&& nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "set NODE_OPTIONS=--no-deprecation&& nuxt preview",
    "reset": "rm -rf .nuxt node_modules .output package-lock.json && npm install",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "set NODE_OPTIONS=--no-deprecation&& nuxt prepare"
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.1",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/image": "^1.7.0",
    "@nuxtjs/google-fonts": "^3.0.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@vue/test-utils": "^2.4.11",
    "nitropack": "^2.13.4",
    "nuxt": "^3.8.2",
    "sass": "^1.60.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.1.10",
    "vuetify": "^3.1.12"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.4.15",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "vee-validate": "^4.15.1",
    "vite-plugin-vuetify": "^1.0.2",
    "zod": "^4.4.3"
  }
}
